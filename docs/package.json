{
    "name": "@vendure-community/docs",
    "version": "1.0.0",
    "description": "Documentation for Vendure community plugins",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "require": "./src/index.ts"
        },
        "./manifest": {
            "import": "./src/manifest.ts",
            "require": "./src/manifest.ts"
        }
    },
    "files": ["src", "docs"],
    "dependencies": {
        "@vendure-io/docs-provider": "^0.11.0"
    },
    "keywords": ["vendure", "documentation", "docs", "community-plugins"],
    "license": "GPL-3.0-or-later",
    "repository": {
        "type": "git",
        "url": "https://github.com/vendurehq/community-plugins",
        "directory": "docs"
    },
    "publishConfig": {
        "access": "public"
    }
}
